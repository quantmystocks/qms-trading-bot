# =============================================================================
# QMS Trading Bot Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Leaderboard API Configuration
# -----------------------------------------------------------------------------
LEADERBOARD_API_URL=https://api.example.com/leaderboard
LEADERBOARD_API_TOKEN=your_leaderboard_api_token_here

# -----------------------------------------------------------------------------
# Broker Configuration
# -----------------------------------------------------------------------------
# Broker type: "alpaca", "robinhood", "webull", or "tradier"
BROKER_TYPE=alpaca

# Alpaca Credentials (required if BROKER_TYPE=alpaca)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
# Alpaca base URL: use "https://paper-api.alpaca.markets" for paper trading
# or "https://api.alpaca.markets" for live trading
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Robinhood Credentials (required if BROKER_TYPE=robinhood)
ROBINHOOD_USERNAME=your_robinhood_username_here
ROBINHOOD_PASSWORD=your_robinhood_password_here
# Optional: MFA code if 2FA is enabled
# ROBINHOOD_MFA_CODE=123456

# Webull Credentials (required if BROKER_TYPE=webull)
# Note: Uses official Webull OpenAPI SDK - requires App Key/Secret from developer.webull.com
# WEBULL_APP_KEY=your_webull_app_key_here
# WEBULL_APP_SECRET=your_webull_app_secret_here
# Optional: Account ID (will use first account if not provided)
# WEBULL_ACCOUNT_ID=your_account_id_here
# Optional: Region (US, HK, or JP) - default: US
# WEBULL_REGION=US

# Tradier Credentials (required if BROKER_TYPE=tradier)
# Get your access token from https://web.tradier.com/user/api
# TRADIER_ACCESS_TOKEN=your_tradier_access_token_here
# TRADIER_ACCOUNT_ID=your_tradier_account_id_here
# Tradier base URL: use "https://sandbox.tradier.com/v1" for paper trading
# or "https://api.tradier.com/v1" for live trading
# TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# -----------------------------------------------------------------------------
# Per-Portfolio Broker Account IDs (Optional)
# -----------------------------------------------------------------------------
# Override the default broker account ID for specific portfolios.
# Useful with Tradier sub-accounts to fully isolate each portfolio.
# If not set, all portfolios share the same broker account.
# BROKER_ACCOUNT_ID_SP500=your_sp500_account_id
# BROKER_ACCOUNT_ID_SP400=your_sp400_account_id
#
# Also supported in PORTFOLIO_CONFIG JSON:
# PORTFOLIO_CONFIG='[{"portfolio_name":"SP500","index_id":"9","initial_capital":10000,"broker_account_id":"ACC123"}]'

# -----------------------------------------------------------------------------
# Trading Configuration
# -----------------------------------------------------------------------------
# Initial capital amount for portfolio allocation (in USD)
INITIAL_CAPITAL=10000.0

# -----------------------------------------------------------------------------
# Portfolio Size & Slack Configuration
# -----------------------------------------------------------------------------
# stockcount: Number of stocks to hold in portfolio (default: 5)
# slack: Position buffer before selling (default: 0)
#        Sell when stock rank > stockcount + slack
#
# Example: stockcount=5, slack=2
#   - Buy stocks ranked 1-5
#   - Hold stocks ranked 1-7
#   - Sell stocks ranked 8+

# Default values (used when not specified per-portfolio)
DEFAULT_STOCKCOUNT=5
DEFAULT_SLACK=0

# Per-portfolio config (legacy format with TRADE_INDICES)
# STOCKCOUNT_SP400=5
# SLACK_SP400=2
# STOCKCOUNT_SP500=10
# SLACK_SP500=3

# JSON format example:
# PORTFOLIO_CONFIG='[
#   {"portfolio_name": "SP400", "index_id": "13", "initial_capital": 10000, "stockcount": 5, "slack": 2},
#   {"portfolio_name": "SP500", "index_id": "9", "initial_capital": 5000, "stockcount": 10, "slack": 0}
# ]'

# -----------------------------------------------------------------------------
# Scheduler Configuration
# -----------------------------------------------------------------------------
# Scheduler mode: "internal" (uses APScheduler) or "external" (uses webhook)
SCHEDULER_MODE=internal
# Cron expression for internal scheduler (default: Monday 9:30 AM New York)
# Format: "minute hour day month day_of_week"
# Example: "30 9 * * 1" = Every Monday at 09:30 in SCHEDULER_TIMEZONE
CRON_SCHEDULE=30 9 * * 1
# Timezone for cron (cron is interpreted in this zone; DST handled automatically)
SCHEDULER_TIMEZONE=America/New_York
# Webhook port (only used if SCHEDULER_MODE=external)
WEBHOOK_PORT=8080
# Optional: Secret token for webhook authentication
# WEBHOOK_SECRET=your_webhook_secret_here

# -----------------------------------------------------------------------------
# Email Notification Configuration
# -----------------------------------------------------------------------------
# Enable/disable email notifications
EMAIL_ENABLED=true
# Recipient email address
EMAIL_RECIPIENT=your_email@example.com
# Email provider: "smtp", "sendgrid", or "ses"
EMAIL_PROVIDER=smtp

# SMTP Configuration (required if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=your_email@gmail.com

# SendGrid Configuration (required if EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=your_verified_email@example.com

# AWS SES Configuration (required if EMAIL_PROVIDER=ses)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
# SES_FROM_EMAIL=your_verified_email@example.com

# -----------------------------------------------------------------------------
# Persistence Configuration (Optional)
# -----------------------------------------------------------------------------
# Enable persistence tracking (auto-enabled if Firebase credentials are configured)
# PERSISTENCE_ENABLED=true
# Firebase Project ID (get from Firebase Console)
# FIREBASE_PROJECT_ID=your-firebase-project-id
# Option 1: Path to Firebase service account JSON file (for local development)
# FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json
# Option 2: Firebase service account JSON as string (for CI/CD, GitHub Actions)
#          Store the entire JSON file content as an environment variable
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}
#
# Isolate data per environment (same project, no clashes between paper/live):
# Option A: Use a different Firestore database (create via Firebase Console or gcloud)
# FIRESTORE_DATABASE_ID=live
# Option B: Use a collection prefix (e.g. paper_trades, live_trades in same DB)
# PERSISTENCE_COLLECTION_PREFIX=paper_
